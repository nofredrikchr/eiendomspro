# ── EiendomsPRO miljøvariabler ──────────────────────────────────────────────
# Kopier denne fila til ".env" og fyll inn verdiene. .env er git-ignorert.
#
# VIKTIG: Ingen av disse er prefikset VITE_. Det er bevisst — VITE_-variabler
# bakes inn i nettleser-bundelen og blir offentlige. Alle hemmeligheter leses
# kun server-side (Vercel serverless functions i /api).

# ── Neon (PostgreSQL) ───────────────────────────────────────────────────────
# Hentes i Neon → Project → Connection Details → "Connection string" (pooled).
# Brukes av /api via @neondatabase/serverless.
DATABASE_URL=postgres://USER:PASSWORD@HOST/neondb?sslmode=require

# ── Kommende integrasjoner (server-side, ikke aktivt ennå) ──────────────────
# Settes i Vercel → Project → Settings → Environment Variables når de aktiveres.
# Signicat (BankID e-signering)
# SIGNICAT_CLIENT_ID=
# SIGNICAT_CLIENT_SECRET=
# SIGNICAT_ACCOUNT_ID=
# Vipps Faktura
# VIPPS_CLIENT_ID=
# VIPPS_CLIENT_SECRET=
# VIPPS_SUBSCRIPTION_KEY=
# VIPPS_MSN=
# Nets (AvtaleGiro / eFaktura)
# NETS_AVTALEGIRO_KUNDE_NR=
# NETS_API_KEY=
# NETS_BASE_URL=https://test.api.nets.eu
# FINN.no (annonsepublisering)
# FINN_API_KEY=
# FINN_ORG_ID=
